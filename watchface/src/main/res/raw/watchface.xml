<?xml version="1.0"?>
<WatchFace width="450" height="450">
  <Metadata key="CLOCK_TYPE" value="ANALOG"/>
  <Metadata key="PREVIEW_TIME" value="12:00:00"/>

  <!--
    24-hour watch face. Noon at top, midnight at bottom.
    Hand angle formula: SECONDS_IN_DAY / 240 - 180
      - midnight (0s)  → -180° (bottom)
      - noon (43200s)  →    0° (top)
    Sunrise/sunset angles use the same formula.
    Group pivot math: all Groups have x+pivotX*width=225, y+pivotY*height=225
    so they rotate around the face center.
  -->

  <Scene backgroundColor="#FF020814">

    <!--
      Day/night shading approximated from DAY_OF_YEAR for Seattle (lat 47.6°N).

      omega = hour-angle at sunrise/sunset, in degrees from noon (top of face).
      Piecewise-linear cosine approximation with breakpoints at solstices/equinoxes:

        omega = 62.2538
              + 0.344223 * clamp([DAY_OF_YEAR] -   1, 0, 364)
              - 0.029945 * clamp([DAY_OF_YEAR] -  80, 0, 285)
              - 0.623750 * clamp([DAY_OF_YEAR] - 172, 0, 193)
              - 0.000986 * clamp([DAY_OF_YEAR] - 264, 0, 101)
              + 0.361453 * clamp([DAY_OF_YEAR] - 355, 0,  10)

      Range: ~62° (winter, ~8h day) to ~118° (summer, ~16h day). Error ≤ 5°.
      Sunrise arc angle = -omega + dst  (left/morning side of face)
      Sunset  arc angle = +omega + dst  (right/evening side of face)

      DST correction (Seattle observes PDT ~day 67 to ~day 305):
        dst = 15 * clamp([DAY_OF_YEAR] - 67, 0, 1) - 15 * clamp([DAY_OF_YEAR] - 305, 0, 1)
      Adds 15° (1 clock hour) during PDT, 0° during PST. ±7-day error at transitions.
      Longitude offset (~9 min) is omitted as negligible.

      WFF has no variable storage, so each combined expression is written in full.
    -->

    <!-- Night ring: from sunset (+omega) clockwise through midnight to sunrise (-omega).
         Transform children set the dynamic angles; static attributes are fallback placeholders. -->
    <PartDraw x="0" y="0" width="450" height="450">
      <Arc
          startAngle="90" endAngle="-90"
           centerX="225" centerY="225" width="420" height="420">
        <Transform target="startAngle" value="62.2538 + 0.344223 * clamp([DAY_OF_YEAR] - 1, 0, 364) - 0.029945 * clamp([DAY_OF_YEAR] - 80, 0, 285) - 0.623750 * clamp([DAY_OF_YEAR] - 172, 0, 193) - 0.000986 * clamp([DAY_OF_YEAR] - 264, 0, 101) + 0.361453 * clamp([DAY_OF_YEAR] - 355, 0, 10) + 15 * clamp([DAY_OF_YEAR] - 67, 0, 1) - 15 * clamp([DAY_OF_YEAR] - 305, 0, 1)"/>
        <Transform target="endAngle" value="-62.2538 - 0.344223 * clamp([DAY_OF_YEAR] - 1, 0, 364) + 0.029945 * clamp([DAY_OF_YEAR] - 80, 0, 285) + 0.623750 * clamp([DAY_OF_YEAR] - 172, 0, 193) + 0.000986 * clamp([DAY_OF_YEAR] - 264, 0, 101) - 0.361453 * clamp([DAY_OF_YEAR] - 355, 0, 10) + 15 * clamp([DAY_OF_YEAR] - 67, 0, 1) - 15 * clamp([DAY_OF_YEAR] - 305, 0, 1)"/>
        <Stroke color="#FF202030" thickness="20"/>
      </Arc>
    </PartDraw>

    <!-- Daytime ring: bright arc from sunrise to sunset -->
    <PartDraw x="0" y="0" width="450" height="450">
      <Arc
          startAngle="-90" endAngle="90"
           centerX="225" centerY="225" width="420" height="420">
        <Transform target="startAngle" value="-62.2538 - 0.344223 * clamp([DAY_OF_YEAR] - 1, 0, 364) + 0.029945 * clamp([DAY_OF_YEAR] - 80, 0, 285) + 0.623750 * clamp([DAY_OF_YEAR] - 172, 0, 193) + 0.000986 * clamp([DAY_OF_YEAR] - 264, 0, 101) - 0.361453 * clamp([DAY_OF_YEAR] - 355, 0, 10) + 15 * clamp([DAY_OF_YEAR] - 67, 0, 1) - 15 * clamp([DAY_OF_YEAR] - 305, 0, 1)"/>
        <Transform target="endAngle" value="62.2538 + 0.344223 * clamp([DAY_OF_YEAR] - 1, 0, 364) - 0.029945 * clamp([DAY_OF_YEAR] - 80, 0, 285) - 0.623750 * clamp([DAY_OF_YEAR] - 172, 0, 193) - 0.000986 * clamp([DAY_OF_YEAR] - 264, 0, 101) + 0.361453 * clamp([DAY_OF_YEAR] - 355, 0, 10) + 15 * clamp([DAY_OF_YEAR] - 67, 0, 1) - 15 * clamp([DAY_OF_YEAR] - 305, 0, 1)"/>
        <Stroke color="#80FFE878" thickness="20"/>
      </Arc>
    </PartDraw>

    <!--
      24 hour tick marks.
      Each Group: x=224, y=7, width=2, height=218, pivotX=0.5, pivotY=1.0
        pivot_x = 224 + 0.5*2 = 225 (face center)
        pivot_y = 7 + 1.0*218 = 225 (face center)
      Tick rectangle drawn at top of local coord space (y=0 to y=13).
      Major ticks (noon/midnight): x=223, width=4, height=18.
      Hour H angle: (H - 12) * 15 degrees.
    -->

    <!-- H=0  midnight  180° MAJOR -->
    <Group name="tick_h00" x="223" y="7" width="4" height="218" pivotX="0.5" pivotY="1.0">
      <Transform target="angle" value="180"/>
      <PartDraw x="0" y="0" width="4" height="18">
        <Rectangle x="0" y="0" width="4" height="18"><Fill color="#FFFFFFFF"/></Rectangle>
      </PartDraw>
    </Group>

    <!-- H=1  1am  195° -->
    <Group name="tick_h01" x="224" y="7" width="2" height="218" pivotX="0.5" pivotY="1.0">
