    <!--
      Hour hand: 24-hour rotation, noon at top.
      x=222, width=6  → pivot_x = 222 + 0.5*6 = 225
      y=33,  height=192 → pivot_y = 33 + 1.0*192 = 225
      Hand tip reaches r=192 from center (inside the ring at r=198-218).
    -->
    <Group name="hour_hand" x="222" y="33" width="6" height="192" pivotX="0.5" pivotY="1.0">
      <Transform target="angle" value="[SECONDS_IN_DAY] / 240 - 180"/>
      <PartDraw x="0" y="0" width="6" height="192">
        <RoundRectangle x="0" y="0" width="6" height="192" cornerRadiusX="3" cornerRadiusY="3">
          <Fill color="#FFFFFFFF"/>
        </RoundRectangle>
      </PartDraw>
    </Group>

    <!-- Center dot -->
    <PartDraw x="215" y="215" width="20" height="20">
      <RoundRectangle x="0" y="0" width="20" height="20" cornerRadiusX="10" cornerRadiusY="10">
        <Fill color="#FFFFFFFF"/>
      </RoundRectangle>
    </PartDraw>

  </Scene>
</WatchFace>
