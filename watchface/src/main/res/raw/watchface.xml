    <!--
      Complication slots at the thirds: noon (top), 9 pm (lower-right), 3 am (lower-left).
      All slots include EMPTY so the user can leave any slot blank.
      Slot size 80×80, radius 120px from face center (225,225).
      Each slot renders SHORT_TEXT (icon above value if icon present, else centered text)
      and SMALL_IMAGE. Both use white-on-dark styling to match the face.
    -->

    <!-- Slot 0: noon (0° / top) -->
    <ComplicationSlot slotId="0" x="145" y="65" width="160" height="80"
                      name="noon" displayName="Noon"
                      supportedTypes="EMPTY SHORT_TEXT LONG_TEXT MONOCHROMATIC_IMAGE SMALL_IMAGE">
      <BoundingRoundBox x="0" y="0" width="160" height="80" cornerRadius="40" outlinePadding="1"/>
      <Complication type="SHORT_TEXT">
        <PartDraw x="0" y="0" width="160" height="80">
          <RoundRectangle x="1" y="1" width="158" height="78" cornerRadiusX="39" cornerRadiusY="39">
            <Stroke color="#40FFFFFF" thickness="1"/>
          </RoundRectangle>
        </PartDraw>
        <Condition>
          <Expressions>
            <Expression name="noon_hasIcon"><![CDATA[[COMPLICATION.MONOCHROMATIC_IMAGE] != null]]></Expression>
          </Expressions>
          <Compare expression="noon_hasIcon">
            <PartImage x="16" y="26" width="28" height="28">
              <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]"/>
            </PartImage>
            <PartText x="52" y="0" width="100" height="80">
              <Text ellipsis="TRUE">
                <Font family="SYNC_TO_DEVICE" size="22"
                    color="#CCFFFFFF">
                  <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                </Font>
              </Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="0" y="0" width="160" height="80">
              <Text align="CENTER" ellipsis="TRUE">
                <Font family="SYNC_TO_DEVICE" size="22"
                    color="#CCFFFFFF">
                  <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                </Font>
              </Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="LONG_TEXT">
        <Condition>
          <Expressions>
            <Expression name="noon_lt_hasTitle"><![CDATA[[COMPLICATION.TITLE] != null]]></Expression>
          </Expressions>
          <Compare expression="noon_lt_hasTitle">
            <PartText x="8" y="8" width="144" height="22">
              <Text align="CENTER" ellipsis="TRUE">
                <Font family="SYNC_TO_DEVICE" size="15" color="#99FFFFFF">
                  <Template>%s<Parameter expression="[COMPLICATION.TITLE]"/></Template>
                </Font>
              </Text>
            </PartText>
            <PartText x="8" y="34" width="144" height="40">
              <Text align="CENTER" ellipsis="TRUE">
                <Font family="SYNC_TO_DEVICE" size="20" color="#CCFFFFFF">
                  <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                </Font>
              </Text>
            </PartText>
          </Compare>
          <Default>
            <PartText x="8" y="0" width="144" height="80">
              <Text align="CENTER" ellipsis="TRUE">
                <Font family="SYNC_TO_DEVICE" size="20" color="#CCFFFFFF">
                  <Template>%s<Parameter expression="[COMPLICATION.TEXT]"/></Template>
                </Font>
              </Text>
            </PartText>
          </Default>
        </Condition>
      </Complication>
      <Complication type="MONOCHROMATIC_IMAGE">
        <PartImage x="56" y="16" width="48" height="48">
          <Image resource="[COMPLICATION.MONOCHROMATIC_IMAGE]"/>
        </PartImage>
      </Complication>
      <Complication type="SMALL_IMAGE">
        <PartImage x="48" y="8" width="64" height="64">
          <Image resource="[COMPLICATION.SMALL_IMAGE]"/>
        </PartImage>
      </Complication>
    </ComplicationSlot>

    <!-- Slot 1: 9 pm (135° clockwise from noon, lower-right) -->
    <ComplicationSlot slotId="1" x="270" y="270" width="80" height="80"
